#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
CONTEXT="$SKILL_ROOT/bin/lionclaw-private-context"

if [[ ! -x "$CONTEXT" ]]; then
  echo "missing private context binary: $CONTEXT" >&2
  echo "reinstall the lionclaw-private-context skill from a LionClaw build that includes lionclaw-private-context" >&2
  exit 127
fi

exec "$CONTEXT" context "$@"
