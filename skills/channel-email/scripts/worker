#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
WORKER="$SKILL_ROOT/bin/lionclaw-channel-email"

if [[ ! -x "$WORKER" ]]; then
  echo "missing email worker binary: $WORKER" >&2
  echo "reinstall the bundled email channel from a LionClaw build that includes lionclaw-channel-email" >&2
  exit 127
fi

exec "$WORKER" "$@"
