ARG RUNTIME_IMAGE=lionclaw-runtime:v1
ARG RUST_IMAGE=docker.io/library/rust:1.95.0-bookworm

FROM ${RUST_IMAGE} AS rust-toolchain
RUN rustup component add \
        clippy \
        rust-analyzer \
        rust-src \
        rustfmt

FROM ${RUNTIME_IMAGE}

# Dev inherits Codex from the runtime image; assert the expected runtime pin.
ARG CODEX_VERSION=0.134.0

USER root

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        build-essential \
        clang \
        cmake \
        gdb \
        libsqlite3-dev \
        libssl-dev \
        lld \
        pkg-config \
        sqlite3 \
        strace \
        tini \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY --from=rust-toolchain /usr/local/cargo /usr/local/cargo
COPY --from=rust-toolchain /usr/local/rustup /usr/local/rustup

ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/runtime/cargo \
    PATH=/runtime/cargo/bin:/usr/local/cargo/bin:${PATH} \
    RUST_BACKTRACE=1

RUN install -d -o lionclaw -g lionclaw /runtime /runtime/cargo \
    && chmod -R u+rwX,go+rX,go-w /usr/local/cargo /usr/local/rustup \
    && printf '%s\n' \
        'export RUSTUP_HOME=/usr/local/rustup' \
        'export CARGO_HOME=/runtime/cargo' \
        'case ":${PATH}:" in *:/usr/local/cargo/bin:*) ;; *) PATH="/usr/local/cargo/bin:${PATH}" ;; esac' \
        'case ":${PATH}:" in *:/runtime/cargo/bin:*) ;; *) PATH="/runtime/cargo/bin:${PATH}" ;; esac' \
        'export PATH' \
        > /etc/profile.d/lionclaw-rust.sh \
    && for tool in \
        cargo \
        cargo-clippy \
        cargo-fmt \
        clippy-driver \
        rust-analyzer \
        rust-gdb \
        rust-lldb \
        rustup \
        rustc \
        rustdoc \
        rustfmt; do \
        ln -sf "/usr/local/cargo/bin/${tool}" "/usr/local/bin/${tool}"; \
    done

USER lionclaw
WORKDIR /workspace

RUN rustc --version \
    && npm ls -g @openai/codex --depth=0 --json \
        | jq -e --arg version "${CODEX_VERSION}" \
            '.dependencies["@openai/codex"].version == $version' \
            >/dev/null \
    && cargo --version \
    && cargo fmt --version \
    && cargo clippy --version \
    && rust-analyzer --version

ENTRYPOINT ["/usr/bin/tini", "--"]
