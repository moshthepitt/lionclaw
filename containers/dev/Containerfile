ARG RUNTIME_IMAGE=lionclaw-runtime:v1
ARG RUST_IMAGE=docker.io/library/rust:1.96.0-bookworm
ARG UV_IMAGE=ghcr.io/astral-sh/uv:0.8.22

FROM ${RUST_IMAGE} AS rust-toolchain
RUN rustup component add \
        clippy \
        rust-analyzer \
        rust-src \
        rustfmt

FROM ${UV_IMAGE} AS uv-bin

FROM ${RUNTIME_IMAGE}

# Dev inherits runtime CLIs from the runtime image; assert the required packages
# are present without duplicating the runtime image's version pins. Layer the
# repo-specific build and test tools here so this image can run scripts/ci.sh.

USER root

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        build-essential \
        clang \
        cmake \
        gdb \
        libsqlite3-dev \
        libssl-dev \
        lld \
        pkg-config \
        sqlite3 \
        strace \
        tini \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY --from=rust-toolchain /usr/local/cargo /usr/local/cargo
COPY --from=rust-toolchain /usr/local/rustup /usr/local/rustup
COPY --from=uv-bin /uv /uvx /usr/local/bin/

ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/runtime/cargo \
    UV_CACHE_DIR=/runtime/uv/cache \
    UV_LINK_MODE=copy \
    UV_PYTHON=3.12 \
    UV_PYTHON_INSTALL_DIR=/opt/lionclaw/uv/python \
    PATH=/runtime/cargo/bin:/usr/local/cargo/bin:${PATH} \
    RUST_BACKTRACE=1

RUN install -d -o lionclaw -g lionclaw \
        /opt/lionclaw/uv/python \
        /runtime \
        /runtime/cargo \
        /runtime/uv \
        /runtime/uv/cache \
    && chmod -R u+rwX,go+rX,go-w /usr/local/cargo /usr/local/rustup \
    && printf '%s\n' \
        'export RUSTUP_HOME=/usr/local/rustup' \
        'export CARGO_HOME=/runtime/cargo' \
        'export UV_CACHE_DIR=/runtime/uv/cache' \
        'export UV_LINK_MODE=copy' \
        'export UV_PYTHON=3.12' \
        'export UV_PYTHON_INSTALL_DIR=/opt/lionclaw/uv/python' \
        'case ":${PATH}:" in *:/usr/local/cargo/bin:*) ;; *) PATH="/usr/local/cargo/bin:${PATH}" ;; esac' \
        'case ":${PATH}:" in *:/runtime/cargo/bin:*) ;; *) PATH="/runtime/cargo/bin:${PATH}" ;; esac' \
        'export PATH' \
        > /etc/profile.d/lionclaw-rust.sh \
    && for tool in \
        cargo \
        cargo-clippy \
        cargo-fmt \
        clippy-driver \
        rust-analyzer \
        rust-gdb \
        rust-lldb \
        rustup \
        rustc \
        rustdoc \
        rustfmt; do \
        ln -sf "/usr/local/cargo/bin/${tool}" "/usr/local/bin/${tool}"; \
    done

USER lionclaw
WORKDIR /workspace

RUN uv python install 3.12 \
    && rustc --version | grep '1.96.0' \
    && npm ls -g @openai/codex opencode-ai --depth=0 --json \
        | jq -e \
            '.dependencies["@openai/codex"].version and .dependencies["opencode-ai"].version' \
            >/dev/null \
    && uv --version \
    && uv python find 3.12 \
    && cargo --version \
    && cargo fmt --version \
    && cargo clippy --version \
    && rust-analyzer --version

ENTRYPOINT ["/usr/bin/tini", "--"]
