FROM node:22-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        git \
        openssh-client \
        ripgrep \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g \
    @openai/codex \
    opencode-ai

RUN useradd --create-home --shell /bin/bash lionclaw

USER lionclaw
WORKDIR /workspace
